{
  "name": "@tt/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "push": "dotenv -e ../../.env -- prisma db push",
    "lint": "echo 'lint placeholder'"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
